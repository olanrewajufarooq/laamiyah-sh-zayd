\newcommand{\bookish@poemseparatorcontent}{%
  \ifdefstring{\bookish@poemseparator}{drawn}{%
    \bookish@drawnpoemseparator
  }{%
    \ifdefstring{\bookish@poemseparator}{auto}{%
      \bookish@drawnpoemseparator
    }{%
      \includegraphics[width=\bookish@poemseparatorimagedefaultwidth,height=\bookish@poemseparatorimagedefaultheight,keepaspectratio]{\bookish@poemseparator}%
    }%
  }%
}

\newcommand{\bookish@resolvepoemseparatorboxwidth}{%
  \ifdefstring{\bookish@poemseparator}{drawn}{%
    \def\bookish@activepoemseparatorboxwidth{\bookish@poemseparatorwidth}%
  }{%
    \ifdefstring{\bookish@poemseparator}{auto}{%
      \def\bookish@activepoemseparatorboxwidth{\bookish@poemseparatorwidth}%
    }{%
      \def\bookish@activepoemseparatorboxwidth{\bookish@poemseparatorimagedefaultwidth}%
    }%
  }%
}

\newcommand{\bookish@specialfootercommon}{%
  \par\medskip
  \ifx\bookish@special@reference\@empty\else
    {\bookishsansfont\fontsize{\bookish@metafontsize pt}{\dimexpr \bookish@metafontsize pt + 3pt\relax}\selectfont\color{bookishaccent}\raggedleft \bookish@special@reference\par}%
  \fi
}

\newcommand{\bookish@specialfooterhadith}{%
  \par\medskip
  \ifx\bookish@special@reference\@empty
    \ifx\bookish@special@grade\@empty\else
      {\bookishsansfont\fontsize{\bookish@metafontsize pt}{\dimexpr \bookish@metafontsize pt + 3pt\relax}\selectfont\color{bookishtext}\centering\textbf{Grade:} \bookish@special@grade\par}%
    \fi
  \else
    \ifx\bookish@special@grade\@empty
      {\bookishsansfont\fontsize{\bookish@metafontsize pt}{\dimexpr \bookish@metafontsize pt + 3pt\relax}\selectfont\color{bookishaccent}\raggedleft \bookish@special@reference\par}%
    \else
      {\bookishsansfont\fontsize{\bookish@metafontsize pt}{\dimexpr \bookish@metafontsize pt + 3pt\relax}\selectfont
      \noindent
      \makebox[\linewidth][l]{\color{bookishtext}\textbf{Grade:} \bookish@special@grade}%
      \makebox[0pt][r]{\color{bookishaccent}\bookish@special@reference}\par}%
    \fi
  \fi
}

\newcommand{\bookish@specialopen}[1]{%
  \bookish@specialresolve{#1}%
  \ifdefstring{\bookish@resolvedspecialstyle}{framed}{%
    \begin{tcolorbox}[enhanced,breakable,colback=bookishsoft,colframe=bookishaccent,boxrule=0.5pt,arc=3pt,left=10pt,right=10pt,top=10pt,bottom=10pt]%
  }{%
    \ifdefstring{\bookish@resolvedspecialstyle}{centered}{%
      \begin{tcolorbox}[enhanced,breakable,colback=white,boxrule=0pt,left=10pt,right=10pt,top=10pt,bottom=10pt,borderline north={0.8pt}{0pt}{bookishaccent},borderline south={0.8pt}{0pt}{bookishaccent}]%
    }{%
      \ifdefstring{\bookish@resolvedspecialstyle}{ornament}{%
        \begin{tcolorbox}[enhanced,breakable,colback=white,boxrule=0pt,left=10pt,right=10pt,top=10pt,bottom=10pt,borderline north={0.8pt}{0pt}{bookishaccent},borderline south={0.8pt}{0pt}{bookishaccent}]%
      }{%
        \begin{tcolorbox}[enhanced,breakable,colback=white,boxrule=0pt,left=10pt,right=10pt,top=10pt,bottom=10pt,borderline west={1.5pt}{0pt}{bookishaccent}]%
      }%
    }%
  }%
}

% Quran, hadith, and athar share the same box machinery but keep separate
% defaults so users can tune them independently.
\NewDocumentEnvironment{quran}{}%
  {\bookish@specialreset\bookish@specialopen{\bookish@quranstyle}\bookish@specialbodyfont{quran}{\bookish@quranfontsize}\ignorespaces}
  {\bookish@specialbodytranslation\bookish@specialfootercommon\end{tcolorbox}}

\NewDocumentEnvironment{hadith}{}%
  {\bookish@specialreset\bookish@specialopen{\bookish@hadithstyle}\bookish@specialbodyfont{hadith}{\bookish@hadithfontsize}\ignorespaces}
  {\bookish@specialbodytranslation\bookish@specialfooterhadith\end{tcolorbox}}

\NewDocumentEnvironment{athar}{}%
  {\bookish@specialreset\bookish@specialopen{\bookish@atharstyle}\bookish@specialbodyfont{athar}{\bookish@atharfontsize}\ignorespaces}
  {\bookish@specialbodytranslation\bookish@specialfootercommon\end{tcolorbox}}

\NewDocumentEnvironment{arabicblock}{}%
  {\bookish@specialreset\bookish@specialopen{\bookish@arabicblockstyle}\bookish@specialbodyfont{arabic}{\bookish@arabicblockfontsize}\ignorespaces}
  {\bookish@specialbodytranslation\end{tcolorbox}}

% Poem lines are set in a two-column Arabic table separated by the supplied art.
% Users write lines in a matrix-like form: first hemistich & second hemistich \\ ...
\NewDocumentEnvironment{poem}{}%
  {%
    \begin{center}%
      \bookisharabicfont
      \bookish@chapterfontsize{\bookish@poemfontsize}%
      \bookish@resolvepoemseparatorboxwidth
      \offinterlineskip
      \let\\\cr
      \hbox to \linewidth\bgroup\hfil
      \vbox\bgroup
      \halign\bgroup
      \hbox to \bookish@poemcolumnwidth{\hfil##\hfil}&\hskip\bookish@poemseparatorgap\makebox[\bookish@activepoemseparatorboxwidth][c]{\bookish@poemseparatorcontent}\hskip\bookish@poemseparatorgap\hbox to \bookish@poemcolumnwidth{\hfil##\hfil}\cr
  }{%
      \crcr\egroup
      \egroup
      \hfil\egroup
    \end{center}%
  }
