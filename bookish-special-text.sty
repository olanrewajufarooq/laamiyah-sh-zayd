\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bookish-special-text}[2026/04/18 Quran, hadith, athar, Arabic, and poem blocks]
% Usage:
% \customizespecialtext{quranstyle=ornament,hadithstyle=framed,poemseparator={assets/images/poem-separator.png}}
% \begin{quran} ... \begin{reference}Surah ...\end{reference} \end{quran}
% \begin{hadith} ... \begin{reference}Bukhari ...\end{reference}\begin{grade}Sahih\end{grade}\end{hadith}

\RequirePackage{xparse}
\RequirePackage{array}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\RequirePackage{tcolorbox}
\tcbuselibrary{breakable,skins}

% Generic style assignment means users can map the same visual treatment to
% Quran, hadith, athar, or generic Arabic blocks without changing the env names.
% "default" and "auto" resolve to the package's recommended Quran treatment.
\newcommand{\bookish@defaultspecialstyle}{ornament}
\newcommand{\bookish@quranstyle}{default}
\newcommand{\bookish@hadithstyle}{auto}
\newcommand{\bookish@atharstyle}{auto}
\newcommand{\bookish@arabicblockstyle}{centered}
\newcommand{\bookish@quranfontsize}{22}
\newcommand{\bookish@hadithfontsize}{18}
\newcommand{\bookish@atharfontsize}{18}
\newcommand{\bookish@arabicblockfontsize}{18}
\newcommand{\bookish@metafontsize}{11}
\newcommand{\bookish@poemfontsize}{18}
\newcommand{\bookish@poemseparator}{drawn}
\newcommand{\bookish@poemseparatorheight}{0.7em}
\newcommand{\bookish@poemseparatorwidth}{0.9em}
% Image separators need a looser default footprint than the drawn TikZ variant,
% but this stays internal so the public API remains one width/height pair.
\newcommand{\bookish@poemseparatorimagedefaultheight}{1.1em}
\newcommand{\bookish@poemseparatorimagedefaultwidth}{1.8em}
\newcommand{\bookish@poemcolumnwidth}{0.47\linewidth}
\newcommand{\bookish@poemseparatorgap}{0.2em}

\pgfkeys{
  /bookish/specialtext/.is family,
  /bookish/specialtext,
  quranstyle/.store in=\bookish@quranstyle,
  hadithstyle/.store in=\bookish@hadithstyle,
  atharstyle/.store in=\bookish@atharstyle,
  arabicstyle/.store in=\bookish@arabicblockstyle,
  quranfontsize/.store in=\bookish@quranfontsize,
  hadithfontsize/.store in=\bookish@hadithfontsize,
  atharfontsize/.store in=\bookish@atharfontsize,
  arabicfontsize/.store in=\bookish@arabicblockfontsize,
  metfontsize/.store in=\bookish@metafontsize,
  metafontsize/.store in=\bookish@metafontsize,
  poemfontsize/.store in=\bookish@poemfontsize,
  poemseparator/.store in=\bookish@poemseparator,
  poemseparatorheight/.store in=\bookish@poemseparatorheight,
  poemseparatorwidth/.store in=\bookish@poemseparatorwidth,
  poemcolumnwidth/.store in=\bookish@poemcolumnwidth,
  poemseparatorgap/.store in=\bookish@poemseparatorgap
}

\newcommand{\customizespecialtext}[1]{\pgfkeys{/bookish/specialtext,#1}}

% Reference, grade, and translation are implemented as inner environments so
% users can place them naturally inside quran/hadith/athar/arabic blocks
% without remembering extra args.
\newcommand{\bookish@special@reference}{}
\newcommand{\bookish@special@grade}{}
\newcommand{\bookish@special@translation}{}

\NewDocumentEnvironment{reference}{+b}
  {\def\bookish@special@reference{#1}\ignorespaces}
  {\ignorespacesafterend}

\NewDocumentEnvironment{grade}{+b}
  {\def\bookish@special@grade{#1}\ignorespaces}
  {\ignorespacesafterend}

\NewDocumentEnvironment{translation}{+b}
  {\def\bookish@special@translation{#1}\ignorespaces}
  {\ignorespacesafterend}

\newcommand{\bookish@specialreset}{%
  \def\bookish@special@reference{}%
  \def\bookish@special@grade{}%
  \def\bookish@special@translation{}%
}

\newcommand{\bookish@specialbodyfont}[2]{%
  \bookisharabicfont
  \bookish@chapterfontsize{#2}%
  \centering
  \color{bookishtext}%
}

\newcommand{\bookish@specialresolve}[1]{%
  \def\bookish@resolvedspecialstyle{#1}%
  \ifdefstring{\bookish@resolvedspecialstyle}{default}{%
    \edef\bookish@resolvedspecialstyle{\bookish@defaultspecialstyle}%
  }{}%
  \ifdefstring{\bookish@resolvedspecialstyle}{auto}{%
    \edef\bookish@resolvedspecialstyle{\bookish@defaultspecialstyle}%
  }{}%
}

\newcommand{\bookish@specialbodytranslation}{%
  \ifx\bookish@special@translation\@empty\else
    \par\medskip
    {\bookishseriffont\itshape\fontsize{\bookish@metafontsize pt}{\dimexpr \bookish@metafontsize pt + 5pt\relax}\selectfont\color{bookishtext}\centering \bookish@special@translation\par}%
  \fi
}

