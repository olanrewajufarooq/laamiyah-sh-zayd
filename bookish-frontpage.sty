\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bookish-frontpage}[2026/04/17 Frontpage styles for bookish]
% Usage:
% Loaded by bookish.sty. Select with \usepackage[frontpage=hexagon]{bookish}
% Available styles: hexagon, star, flower, circle.
% Matching backmatter pages are rendered through \bookmakebackmatter.

% Frontpage rendering relies on TikZ composition and a few helper comparisons.
\RequirePackage{etoolbox}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{calc,math,positioning,shapes.geometric}

\newcommand{\bookishfrontpage@style}{hexagon}

% Store the public frontpage style name for later dispatch.
\newcommand{\bookishfrontpagesetup}[1]{%
  \edef\bookishfrontpage@style{#1}%
}

% Shared drawing helpers used by the geometric cover styles.
\newcommand{\bookish@drawhexagon}[5]{%
  \node[
    rounded corners,
    inner sep=0pt,
    ultra thick,
    regular polygon,
    regular polygon sides=6,
    minimum size=#3,
    rotate=#4,
    #5
  ] at (#2) {#1}%
}

\newcommand{\bookish@drawtext}[5]{%
  \node[
    left,
    bookishcoverbg,
    rounded corners,
    minimum width=\paperwidth,
    minimum height=#3,
    text width=\paperwidth,
    rotate=#4,
    #5
  ] at (#2) {#1}%
}

% Geometry helpers for the Forta-style emblem used by the elegant cover.
\newcommand{\bookish@pentagonvertex}[5]{%
  ({#1 + #3*cos(72*#5 + #4)},{#2 + #3*sin(72*#5 + #4)})%
}

\newcommand{\bookish@drawfortalogo}[7]{%
  \foreach \i [evaluate=\i as \j using {int(mod(\i+1,5))},
               evaluate=\i as \Aout using {#6 + 90 + #5 + \i*72},
               evaluate=\i as \Bin using {#6 - 90 - #5 + \i*72},
               evaluate=\i as \Bout using {#6 + 180 + #5 + \i*72},
               evaluate=\i as \Cin using {#6 - #5 + \i*72},
               evaluate=\i as \Cout using {#6 + 72 + #5 + \i*72},
               evaluate=\i as \Din using {#6 + 252 - #5 + \i*72}] in {0,1,2,3,4} {%
    \path let \p1 = \bookish@pentagonvertex{#1}{#2}{#3}{#6-0.5*#4}{\i},
              \p2 = \bookish@pentagonvertex{#1}{#2}{#3}{#6+0.5*#4}{\i},
              \p3 = \bookish@pentagonvertex{#1}{#2}{0.4*#3}{#6+36}{\i},
              \p4 = \bookish@pentagonvertex{#1}{#2}{#3}{#6-0.5*#4}{\j}
          in coordinate (A) at (\p1)
             coordinate (B) at (\p2)
             coordinate (C) at (\p3)
             coordinate (D) at (\p4);
    \draw[#7] (A) to[out=\Aout,in=\Bin] (B)
              to[out=\Bout,in=\Cin] (C)
              to[out=\Cout,in=\Din] (D);
  }%
}

% Shared publisher helpers keep logo rendering optional across all styles.
\newcommand{\bookish@publishername}{%
  \bookish@imprint%
}

\newcommand{\bookish@publishstatuslabel}{%
  \ifdefstring{\bookish@publishstatus}{demo}{Demo}{%
    \ifdefstring{\bookish@publishstatus}{review}{For Review}{%
      \ifdefstring{\bookish@publishstatus}{published}{}{%
        \bookish@publishstatus%
      }%
    }%
  }%
}

\newcommand{\bookish@drawpublisherlogo}[2]{%
  \ifstrempty{\bookish@publisherlogo}{}{%
    \node[#1] {\includegraphics[width=#2]{\bookish@publisherlogo}};%
  }%
}

% The hexagon cover needs slightly stricter stroke geometry than the other styles.
\newcommand{\bookish@drawcoverhexagon}[5]{%
  \node[
    rounded corners=2pt,
    inner sep=0pt,
    line width=0.9pt,
    regular polygon,
    regular polygon sides=6,
    minimum size=#3,
    rotate=#4,
    #5
  ] at (#2) {#1}%
}

% Subtitle placement is configurable: above or below the title.
\newcommand{\bookish@ifsubtitleabove}[2]{%
  \ifdefstring{\bookish@subtitleposition}{above}{#1}{#2}%
}

% Hexagon-based cover derived from the original black template layout.
\newcommand{\bookishfrontpagehexagons}{%
  \fill[bookishcoverbg] (current page.south west) rectangle (current page.north east);

  \foreach \i in {0.5,...,20} {%
    \bookish@drawcoverhexagon{}{$(current page.north west)+(2.5,0)$}{\i cm}{0}{bookishcoveraccent!60,draw};%
  }%
  \foreach \i in {2.5,...,22} {%
    \bookish@drawcoverhexagon{}{$(current page.west)+(2.5,-5)$}{\i cm}{0}{bookishcoveraccent!60,draw};%
  }%
  \foreach \i in {0.5,...,22} {%
    \bookish@drawcoverhexagon{}{$(current page.north east)+(0,-8.2)$}{\i cm}{0}{bookishcoveraccent!90,draw};%
  }%
  \foreach \i in {21,...,2} {%
    \bookish@drawcoverhexagon{}{$(current page.south east)+(-0.2,-1.0)$}{\i cm}{0}{bookishcoveraccent!85,draw};%
  }%

  \bookish@drawtext{%
    \bookish@ifsubtitleabove{%
      \ifstrempty{\bookish@subtitle}{}{\large\textsc{\bookish@subtitle}\\[8pt]}%
    }{}%
    \Huge\textsc{\textbf{\bookish@title}}%
    \bookish@ifsubtitleabove{}{%
      \ifstrempty{\bookish@subtitle}{}{\\[6pt]\Large\textsc{\bookish@subtitle}}%
    }%
  }{$(current page.center)+(3.2,-3.2)$}{3cm}{-60}{text=bookishcoverfg,align=right,font=\bookishelegantfont};

  \bookish@drawtext{%
    \ifstrempty{\bookish@authoraddress}{}{\large\textsc{\bookish@authoraddress}\\[2pt]}%
    \Large\textsc{\bookish@author}%
    \ifstrempty{\bookish@year}{}{\\\Large\textsc{\bookish@year}}%
  }{$(current page.east)+(-0.55,-4.85)$}{2cm}{0}{text=bookishcoverfg,anchor=east,align=right,font=\bookishelegantfont};

  \ifstrempty{\bookish@publishstatuslabel}{}{%
    \bookish@drawcoverhexagon{%
      {\bookishelegantfont\Large\bookish@publishstatuslabel}%
    }{$(current page.west)+(2.5,-5)$}{2.5 cm}{0}{bookishcoveraccent!60,draw,text=bookishcoverfg,font=\bookishelegantfont};%
  }%

  \node[
    text=bookishcovermuted,
    anchor=south,
    font=\bookishelegantfont
  ] (publisher) at ([yshift=18pt] current page.south) {%
    \Large\textsc{\bookish@publishername}%
  };
  \bookish@drawpublisherlogo{anchor=north, above=4pt of publisher.north}{0.07\textwidth}
}

% Matching hexagon backmatter page built to echo the frontpage geometry.
\newcommand{\bookishbackmatterhexagons}{%
  \fill[bookishcoverbg] (current page.south west) rectangle (current page.north east);

  \foreach \i in {0.5,...,20} {%
    \bookish@drawcoverhexagon{}{$(current page.north west)+(2.5,0)$}{\i cm}{0}{bookishcoveraccent!60,draw};%
  }%
  \foreach \i in {2.5,...,22} {%
    \bookish@drawcoverhexagon{}{$(current page.west)+(2.5,-5)$}{\i cm}{0}{bookishcoveraccent!60,draw};%
  }%
  \foreach \i in {0.5,...,22} {%
    \bookish@drawcoverhexagon{}{$(current page.north east)+(0,-8.9)$}{\i cm}{0}{bookishcoveraccent!90,draw};%
  }%
  \foreach \i in {21,...,2} {%
    \bookish@drawcoverhexagon{}{$(current page.south east)+(-0.2,-1.0)$}{\i cm}{0}{bookishcoveraccent!85,draw};%
  }%

  \node[
    text=bookishcoverfg,
    text width=.8\paperwidth,
    align=justify,
    anchor=north
  ] at ([yshift=-52pt] current page.north) {%
    \scshape\small
    \ifstrempty{\bookish@backtext}{\bookish@title}{\bookish@backtext}%
  };

  \node[
    text=bookishcovermuted,
    anchor=south,
    font=\bookishcoverfont
  ] (publisher) at ([yshift=20pt] current page.south) {%
    \Large\textsc{\bookish@publishername}%
  };
  \bookish@drawpublisherlogo{anchor=north, above=4pt of publisher.north}{0.07\textwidth}
}

% Elegant Forta-style cover derived from the alternate black template cover.
\newcommand{\bookishfrontpageelegant}{%
  \fill[bookishcoverbg] (current page.south west) rectangle (current page.north east);
  \foreach \i [evaluate=\i as \Ox using {5 + 0.2 * \i},
               evaluate=\i as \Oy using {-4},
               evaluate=\i as \R using {4 + 0.4 * \i},
               evaluate=\i as \Tilt using {36 + 0.5 * \i},
               evaluate=\i as \percent using {100-\i*5}] in {0,...,20} {%
    \bookish@drawfortalogo{\Ox}{\Oy}{\R}{28}{8}{\Tilt}{very thick, densely dotted, draw=bookishcovermuted!\percent!black};%
  }%

  \node[
    text=bookishcoverfg,
    minimum width=\paperwidth,
    minimum height=2cm,
    text width=\paperwidth,
    align=right,
    anchor=east,
    inner sep=0pt,
    outer sep=0pt,
    font=\fontsize{48}{52}\bookishelegantfont\bfseries
  ] at ($(current page.east)+(-0.8,-2)$) {%
    \textsc{\bookish@title}%
  };

  \bookish@ifsubtitleabove{%
    \ifstrempty{\bookish@subtitle}{}{%
      \node[
        text=bookishcovermuted,
        minimum width=.5\paperwidth,
        minimum height=0.8cm,
        text width=.5\paperwidth,
        align=right,
        anchor=east,
        inner sep=0pt,
        outer sep=0pt,
        font=\fontsize{13}{15}\bookishelegantfont
      ] at ($(current page.east)+(-0.8,0.4)$) {%
        \textsc{\bookish@subtitle}%
      };
    }%
  }{%
    \ifstrempty{\bookish@subtitle}{}{%
      \node[
        text=bookishcoverfg,
        minimum width=\paperwidth,
        minimum height=2cm,
        text width=\paperwidth,
        align=right,
        anchor=east,
        inner sep=0pt,
        outer sep=0pt,
        font=\fontsize{18}{20}\bookishelegantfont
      ] at ($(current page.east)+(-0.8,-4.55)$) {%
        \textsc{\bookish@subtitle}%
      };
    }%
  }%

  \node[
    text=bookishcoverfg,
    text width=.38\paperwidth,
    align=right,
    anchor=east,
    font=\fontsize{12}{14}\bookishelegantfont
  ] at ($(current page.south east)+(-2,2)$) {%
    \ifstrempty{\bookish@authoraddress}{}{{\color{bookishcovermuted}\textsc{\bookish@authoraddress}}\\[2pt]}%
    {\fontsize{18}{20}\selectfont\textsc{\textbf{\bookish@author}}}%
    \ifstrempty{\bookish@year}{}{\\[4pt]{\color{bookishcovermuted}\textsc{\bookish@year}}}%
  };

  \bookish@drawpublisherlogo{anchor=south west, at={($(current page.south west)+(0.8,1.35)$)}}{0.08\textwidth}
  \ifstrempty{\bookish@publisherlogo}{}{%
    \node[
      text=bookishcovermuted,
      anchor=north,
      align=left,
      font=\fontsize{12}{12}\bookishelegantfont
    ] at ($(current page.south west)+(1.2,0.8)$) {\textsc{\bookish@publishername}};
  }%
}

% Matching elegant backmatter page reuses the same emblem and text placement.
\newcommand{\bookishbackmatterelegant}{%
