% Convert the normalized ornate frontpage settings above into concrete TikZ coordinates.
% This keeps the public customization API page-size aware instead of relying on hardcoded points.
% The logic here is intentionally repetitive:
% - title and author blocks are measured from the top edge
% - translator and publisher blocks are measured from the bottom edge
% - each block can be centered or attached to the left/right page edge depending
%   on the selected anchor
%
% If you add a new ornate-style frontpage later, you should only need to set the
% normalized variables and then call this helper. Avoid writing raw TikZ
% coordinates in the cover renderer unless the design truly cannot fit this model.
\newcommand{\bookish@refreshornatecoords}{%
  \ifdefstring{\bookish@ornatetitleanchor}{north west}{%
    \xdef\bookish@ornatetitlecoord{([xshift=\bookish@ornatetitlexoffset,yshift=-\bookish@ornatetitlefromtop]current page.north west)}%
  }{%
    \ifdefstring{\bookish@ornatetitleanchor}{north east}{%
      \xdef\bookish@ornatetitlecoord{([xshift=\bookish@ornatetitlexoffset,yshift=-\bookish@ornatetitlefromtop]current page.north east)}%
    }{%
      \xdef\bookish@ornatetitlecoord{([xshift=\bookish@ornatetitlexoffset,yshift=-\bookish@ornatetitlefromtop]current page.north)}%
    }%
  }%
  \ifdefstring{\bookish@ornateauthoranchor}{north west}{%
    \xdef\bookish@ornateauthorcoord{([xshift=\bookish@ornateauthorxoffset,yshift=-\bookish@ornateauthorfromtop]current page.north west)}%
  }{%
    \ifdefstring{\bookish@ornateauthoranchor}{north east}{%
      \xdef\bookish@ornateauthorcoord{([xshift=\bookish@ornateauthorxoffset,yshift=-\bookish@ornateauthorfromtop]current page.north east)}%
    }{%
      \xdef\bookish@ornateauthorcoord{([xshift=\bookish@ornateauthorxoffset,yshift=-\bookish@ornateauthorfromtop]current page.north)}%
    }%
  }%
  \ifdefstring{\bookish@ornatepublisheranchor}{south west}{%
    \xdef\bookish@ornatepublishercoord{([xshift=\bookish@ornatepublisherxoffset,yshift=\bookish@ornatepublisherfrombottom]current page.south west)}%
  }{%
    \ifdefstring{\bookish@ornatepublisheranchor}{south east}{%
      \xdef\bookish@ornatepublishercoord{([xshift=\bookish@ornatepublisherxoffset,yshift=\bookish@ornatepublisherfrombottom]current page.south east)}%
    }{%
      \xdef\bookish@ornatepublishercoord{([xshift=\bookish@ornatepublisherxoffset,yshift=\bookish@ornatepublisherfrombottom]current page.south)}%
    }%
  }%
  \ifdefstring{\bookish@ornatetranslatoranchor}{south west}{%
    \xdef\bookish@ornatetranslatorcoord{([xshift=\bookish@ornatetranslatorxoffset,yshift=\bookish@ornatetranslatorfrombottom]current page.south west)}%
  }{%
    \ifdefstring{\bookish@ornatetranslatoranchor}{south east}{%
      \xdef\bookish@ornatetranslatorcoord{([xshift=\bookish@ornatetranslatorxoffset,yshift=\bookish@ornatetranslatorfrombottom]current page.south east)}%
    }{%
      \xdef\bookish@ornatetranslatorcoord{([xshift=\bookish@ornatetranslatorxoffset,yshift=\bookish@ornatetranslatorfrombottom]current page.south)}%
    }%
  }%
}

