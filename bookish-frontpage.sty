\newcommand{\bookish@setupornatefrontpage}[1]{%
  % Reset to shared ornate defaults, then apply the selected style preset, then user overrides.
  % This function is the only place where the ornate covers merge:
  % 1) package defaults
  % 2) style defaults for `star`, `flower`, or `circle`
  % 3) document-level overrides from `\customizefrontpage`
  % 4) final coordinate materialization
  %
  % If a user reports that `\customizefrontpage` is not affecting one of the
  % ornate covers, this is the first function to inspect.
  \renewcommand{\bookish@ornatetitlexoffset}{-0.04\paperwidth}%
  \renewcommand{\bookish@ornatetitlefromtop}{0.10\paperheight}%
  \renewcommand{\bookish@ornatetitleanchor}{north east}%
  \renewcommand{\bookish@ornatetitlealign}{right}%
  \renewcommand{\bookish@ornatetitlewidth}{0.95\paperwidth}%
  \renewcommand{\bookish@ornatetitlefontsize}{33}%
  \renewcommand{\bookish@ornatesubtitlefontsize}{15}%
  \renewcommand{\bookish@ornateauthorxoffset}{-0.04\paperwidth}%
  \renewcommand{\bookish@ornateauthorfromtop}{0.34\paperheight}%
  \renewcommand{\bookish@ornateauthoranchor}{north east}%
  \renewcommand{\bookish@ornateauthoralign}{right}%
  \renewcommand{\bookish@ornateauthorwidth}{0.95\paperwidth}%
  \renewcommand{\bookish@ornateauthorfontsize}{22}%
  \renewcommand{\bookish@ornateauthoraddressfontsize}{13}%
  \renewcommand{\bookish@ornatetranslatorxoffset}{0pt}%
  \renewcommand{\bookish@ornatetranslatorfrombottom}{0.22\paperheight}%
  \renewcommand{\bookish@ornatetranslatoranchor}{south}%
  \renewcommand{\bookish@ornatetranslatoralign}{center}%
  \renewcommand{\bookish@ornatetranslatorwidth}{0.50\paperwidth}%
  \renewcommand{\bookish@ornatetranslatorfontsize}{12}%
  \renewcommand{\bookish@ornatepublisherxoffset}{0pt}%
  \renewcommand{\bookish@ornatepublisherfrombottom}{0.05\paperheight}%
  \renewcommand{\bookish@ornatepublisheranchor}{south}%
  \renewcommand{\bookish@ornatepublisheralign}{center}%
  \renewcommand{\bookish@ornatepublishernamewidth}{0.32\paperwidth}%
  \renewcommand{\bookish@ornatepublisherlogowidth}{0.07\textwidth}%
  \ifcsdef{bookish@setupornatefrontpage@#1}{%
    \csname bookish@setupornatefrontpage@#1\endcsname
  }{}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@titleblockfromtop}{\bookish@ornatetitlefromtop}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@titleblockwidth}{\bookish@ornatetitlewidth}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@titlefontsize}{\bookish@ornatetitlefontsize}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@subtitlefontsize}{\bookish@ornatesubtitlefontsize}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@authorblockfromtop}{\bookish@ornateauthorfromtop}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@authorblockwidth}{\bookish@ornateauthorwidth}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@authorfontsize}{\bookish@ornateauthorfontsize}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@authoraddressfontsize}{\bookish@ornateauthoraddressfontsize}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@translatorblockfrombottom}{\bookish@ornatetranslatorfrombottom}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@translatorblockwidth}{\bookish@ornatetranslatorwidth}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@translatorfontsize}{\bookish@ornatetranslatorfontsize}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@publisherblockfrombottom}{\bookish@ornatepublisherfrombottom}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@publisherlogowidth}{\bookish@ornatepublisherlogowidth}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@publishernamewidth}{\bookish@ornatepublishernamewidth}%
  \bookish@refreshornatecoords
}

% Default image-background frontpage settings live here so cover tuning is easy to audit.
% These are the baseline values for all photo / illustration-backed frontpages.
% As with the ornate covers, the workflow is: shared defaults -> style preset -> user overrides.
%
% The image-backed covers use the same four content groups as the ornate covers,
% but add one more concern: panel opacity. The image may be calm enough to allow
% bare text, or busy enough to require a soft background panel behind the text.
%
% Variable conventions mirror the ornate system. The main additions are:
% - *panelopacity: background tint behind the title/author/meta blocks
% - *filepath: source image path selected from the public frontpage style name
% - *metapanelopacity: shared panel opacity for translator and publisher blocks
%
% Use TeX lengths for `fromtop` / `frombottom`, `xoffset`, and widths.
