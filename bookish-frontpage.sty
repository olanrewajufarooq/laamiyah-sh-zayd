% Frontpage overrides are passed in from bookish.sty as raw strings.
% Expand them once here before writing into the layout macros so later coordinate math sees final values.
% Without this expansion step, keys such as `titleblockfromtop={0.24\paperheight}` would stay
% as references to the original storage macro and break the later TikZ math.
\newcommand{\bookish@applyfrontpageoverride}[2]{%
  \ifdefempty{#1}{}{%
    \edef\bookish@frontpageoverridevalue{#1}%
    \expandafter\renewcommand\expandafter#2\expandafter{\bookish@frontpageoverridevalue}%
  }%
}

% Convert the normalized image-cover settings into concrete TikZ coordinates.
% This is called after defaults, style-specific tweaks, and user overrides have all been applied.
% Like the ornate coordinate helper above, this isolates the page-geometry math
% from the actual drawing code. That separation makes it possible to keep the
% renderer stable while moving blocks around through defaults and user overrides.
\newcommand{\bookish@refreshimagebgcoords}{%
  \ifdefstring{\bookish@imagebgtitleanchor}{north west}{%
    \xdef\bookish@imagebgtitlecoord{([xshift=\bookish@imagebgtitlexoffset,yshift=-\bookish@imagebgtitlefromtop]current page.north west)}%
