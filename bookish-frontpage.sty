        }
      }
    }
    \foreach \l in {1, 2, ..., 8}{%
      \foreach \i in {-1, 0, 1, 2, ..., 8}{%
        \path (0,0) pic {petalPiece={\l}{\i}};
      }%
    }%
  \end{scope}

  \node[
    text=bookishcoverfg,
    text width=.84\paperwidth,
    align=justify,
    anchor=north
  ] at ([yshift=-48pt] current page.north) {%
    \scshape\small
    \ifstrempty{\bookish@backtext}{\bookish@title}{\bookish@backtext}%
  };

  \node[anchor=south] (publisher) at ([yshift=18pt] current page.south) {%
    \textcolor{bookishcovermuted}{\scshape\large\bookish@publishername}%
  };

  \bookish@drawpublisherlogo{anchor=north, above=4pt of publisher.north}{0.07\textwidth}
}

% Mid-band spiral/circle cover derived from the warm dark reference layout.
\newcommand{\bookishfrontpagespiralcirclemid}{%
