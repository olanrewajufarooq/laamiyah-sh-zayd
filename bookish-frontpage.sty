% Central floral spiral cover derived from the purple template layout.
% Public style name: flower.
% The flower motif is fixed artwork; title, author, translator, and publisher all use ornate defaults/overrides.
% The key separation here is:
% - motif geometry stays local to this renderer
% - text system stays in the shared ornate layout layer
% That split is what lets `\customizefrontpage` work without duplicating floral geometry code.
\newcommand{\bookishfrontpageflowercenter}{%
  \bookish@setupornatefrontpage{flower}%
  % The original pattern uses the golden ratio to set the central motif scale.
  \pgfmathsetmacro{\phi}{(1+sqrt(5))/2}%
  \pgfmathsetlengthmacro{\goldenHeight}{\paperheight/\phi}%
  \pgfmathsetmacro{\scaleFactor}{\goldenHeight/1cm/6.90}%
  \begin{scope}[remember picture, overlay, shift={(current page.south west)}]
    % Build the vertical background bands from the active theme colors.
    \shade[bottom color=bookishcoverbg, top color=bookishaccent!85!black]
      (0,0) rectangle (\paperwidth,0.5\paperheight);
    \fill[bookishaccent!92!black]
      (0,0.5\paperheight) rectangle (\paperwidth,0.7\paperheight);
    \shade[bottom color=bookishaccent!85!black, top color=bookishcoverbg]
      (0,0.7\paperheight) rectangle (\paperwidth,\paperheight);
  \end{scope}
  \bookish@drawstatustag

  \bookish@ifsubtitleabove{%
    \ifstrempty{\bookish@subtitle}{}{%
      \node[
        white,
        text width=\bookish@ornatetitlewidth,
        align=\bookish@ornatetitlealign,
        anchor=\bookish@ornatetitleanchor,
        font=\bookishsansfont\fontsize{\bookish@ornatesubtitlefontsize}{\numexpr\bookish@ornatesubtitlefontsize+2\relax}\selectfont
      ] (subtitle) at \bookish@ornatetitlecoord {\textcolor{bookishcovermuted}{\bookish@coverSubtitleText{\bookish@subtitle}}};
      \node[
        white,
        anchor=north east,
        text width=\bookish@ornatetitlewidth,
        align=\bookish@ornatetitlealign,
        font=\bookishcoverseriffont\bfseries\fontsize{\bookish@ornatetitlefontsize}{\numexpr\bookish@ornatetitlefontsize+4\relax}\selectfont
      ] (title) at ([yshift=-4pt] subtitle.south east) {\textcolor{bookishcoveraccent}{\bookish@coverTitleText{\bookish@title}}};
    }%
  }{%
    \node[
      white,
      anchor=\bookish@ornatetitleanchor,
      text width=\bookish@ornatetitlewidth,
      align=\bookish@ornatetitlealign,
      font=\bookishcoverseriffont\bfseries\fontsize{\bookish@ornatetitlefontsize}{\numexpr\bookish@ornatetitlefontsize+4\relax}\selectfont
    ] (title) at \bookish@ornatetitlecoord {\textcolor{bookishcoveraccent}{\bookish@coverTitleText{\bookish@title}}};
    \ifstrempty{\bookish@subtitle}{}{%
      \node at ([yshift=-3pt] title.south east) [
        white,
        text width=\bookish@ornatetitlewidth,
        align=\bookish@ornatetitlealign,
        anchor=north east,
        font=\bookishsansfont\fontsize{\bookish@ornatesubtitlefontsize}{\numexpr\bookish@ornatesubtitlefontsize+2\relax}\selectfont
      ] (subtitle) {\textcolor{bookishcovermuted}{\bookish@coverSubtitleText{\bookish@subtitle}}};
    }%
  }%

  \node[
    bookishcoveraccent,
    anchor=\bookish@ornateauthoranchor,
    text width=\bookish@ornateauthorwidth,
    align=\bookish@ornateauthoralign,
    font=\bookishsansfont\fontsize{\bookish@ornateauthoraddressfontsize}{\numexpr\bookish@ornateauthoraddressfontsize+2\relax}\selectfont
  ] (author) at \bookish@ornateauthorcoord {%
    \textcolor{bookishcoverfg}{%
      \ifstrempty{\bookish@authoraddress}{}{\bookish@coverAddressText{\bookish@authoraddress}\\[3pt]}%
      {\fontsize{\bookish@ornateauthorfontsize}{\numexpr\bookish@ornateauthorfontsize+2\relax}\selectfont\bookish@coverAuthorText{\bookish@author}}%
    }%
  };

  \begin{scope}[remember picture, overlay, shift={(current page.center)}]
    % Add the soft circular motif behind the flower.
    \pgfmathsetlengthmacro{\circleradius}{\paperwidth/14}%
    \foreach \i in {0,1,5,6} {%
      \fill[line width=1.5pt, fill=bookishcoverfg, fill opacity=0.2]
        ({(\i - 3)*2*\circleradius}, 0) circle (\circleradius);
    }%
    \fill[line width=1.5pt, fill=bookishcoverfg, fill opacity=0.12]
      (0,0) circle ({0.474*\goldenHeight/\scaleFactor});
  \end{scope}

  \begin{scope}[remember picture, overlay, shift={(current page.center)}, scale=\scaleFactor]
    % Reconstruct the petal spiral using small repeated quadrilateral pieces.
    \tikzmath{
      integer \nbPetals, \nbQuad;
      \nbPetals = 8;
      \nbQuad = 8;
      real \a, \base, \r;
      \a = 360/\nbPetals;
      \base = 2;
      \r = .35;
      function tmpR(\i) {
        return {\r*pow(\base, 2.928*\i/\nbQuad)};
      };
    }
    \tikzset{
      pics/petalPiece/.style 2 args={
        code={
          \tikzmath{integer \b, \p; \b = ##1; \p = ##2;}
          \path
            (\p/\nbQuad*180 +\b*\a: {tmpR(\p)}) coordinate (NW)
            ({(\p +1)/\nbQuad*180 +\b*\a}: {tmpR(\p +1)}) coordinate (NE)
            ({(\p +2)/\nbQuad*180 +(\b -1)*\a}: {tmpR(\p +2)}) coordinate (SE)
            ({(\p +1)/\nbQuad*180 +(\b -1)*\a}: {tmpR(\p +1)}) coordinate (SW);
          \foreach \i in {0, .05, ..., .9}{%
            \draw[bookishcoverfg, thick, fill=bookishcoverfg, opacity=.08]
              ($(NW)!\i!(SW)$) -- ($(NE)!\i/2!(SE)$) -- (SE) -- (SW) -- cycle;
          }%
        }
      }
    }
    \foreach \l in {1, 2, ..., 8}{%
      \foreach \i in {-1, 0, 1, 2, ..., 8}{%
        \path (0,0) pic {petalPiece={\l}{\i}};
      }%
    }%
  \end{scope}

  \node[white, font=\Huge, anchor=south]
    (publisher) at \bookish@ornatepublishercoord
    {\textcolor{bookishcovermuted}{\fontsize{11}{11}\selectfont\parbox{\bookish@ornatepublishernamewidth}{\centering\bookish@coverMetaText{\bookish@publishername}}}};

  \bookish@drawpublisherlogo{anchor=north, above=2pt of publisher.north}{\bookish@ornatepublisherlogowidth}

  \ifstrempty{\bookish@translator}{}{%
    \node[
      white,
      anchor=\bookish@ornatetranslatoranchor,
      text width=\bookish@ornatetranslatorwidth,
      align=\bookish@ornatetranslatoralign,
      font=\fontsize{\bookish@ornatetranslatorfontsize}{\numexpr\bookish@ornatetranslatorfontsize+2\relax}\selectfont
    ] (translatedBy) at \bookish@ornatetranslatorcoord {%
      \textcolor{bookishcovermuted}{\itshape Translated by}\par
      \textcolor{bookishcoverfg}{\fontsize{\numexpr\bookish@ornatetranslatorfontsize+1\relax}{\numexpr\bookish@ornatetranslatorfontsize+3\relax}\selectfont\bookish@translator}%
    };
  }%
}

