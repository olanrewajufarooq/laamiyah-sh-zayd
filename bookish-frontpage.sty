\newcommand{\bookish@ifimagebgstyle}[3]{%
  \expandafter\ifcsname bookish@imagebgstyle@#1\endcsname
    #2%
  \else
    #3%
  \fi
}

% Store the public frontpage style name for later dispatch.
\newcommand{\bookishfrontpagesetup}[1]{%
  \edef\bookishfrontpage@style{#1}%
}

\newcommand{\bookish@drawtext}[5]{%
  \node[
    left,
    bookishcoverbg,
    rounded corners,
    minimum width=\paperwidth,
    minimum height=#3,
    text width=\paperwidth,
    rotate=#4,
    #5
  ] at (#2) {#1}%
}

% Geometry helpers for the Forta-style emblem used by the elegant cover.
\newcommand{\bookish@pentagonvertex}[5]{%
  ({#1 + #3*cos(72*#5 + #4)},{#2 + #3*sin(72*#5 + #4)})%
}

\newcommand{\bookish@drawfortalogo}[7]{%
  \foreach \i [evaluate=\i as \j using {int(mod(\i+1,5))},
               evaluate=\i as \Aout using {#6 + 90 + #5 + \i*72},
               evaluate=\i as \Bin using {#6 - 90 - #5 + \i*72},
               evaluate=\i as \Bout using {#6 + 180 + #5 + \i*72},
               evaluate=\i as \Cin using {#6 - #5 + \i*72},
               evaluate=\i as \Cout using {#6 + 72 + #5 + \i*72},
               evaluate=\i as \Din using {#6 + 252 - #5 + \i*72}] in {0,1,2,3,4} {%
    \path let \p1 = \bookish@pentagonvertex{#1}{#2}{#3}{#6-0.5*#4}{\i},
              \p2 = \bookish@pentagonvertex{#1}{#2}{#3}{#6+0.5*#4}{\i},
              \p3 = \bookish@pentagonvertex{#1}{#2}{0.4*#3}{#6+36}{\i},
              \p4 = \bookish@pentagonvertex{#1}{#2}{#3}{#6-0.5*#4}{\j}
          in coordinate (A) at (\p1)
             coordinate (B) at (\p2)
             coordinate (C) at (\p3)
             coordinate (D) at (\p4);
    \draw[#7] (A) to[out=\Aout,in=\Bin] (B)
              to[out=\Bout,in=\Cin] (C)
              to[out=\Cout,in=\Din] (D);
  }%
}

% Shared publisher helpers keep logo rendering optional across all styles.
\newcommand{\bookish@publishername}{%
  \bookish@imprint%
}

\newcommand{\bookish@publishstatuslabel}{%
  \ifdefstring{\bookish@publishstatus}{demo}{Preview}{%
    \ifdefstring{\bookish@publishstatus}{review}{Review}{%
      \ifdefstring{\bookish@publishstatus}{published}{}{%
        \bookish@publishstatus%
      }%
    }%
  }%
}

% Shared cover typography keeps title, subtitle, author, and metadata consistent.
\newcommand{\bookish@coverTitleText}[1]{%
  {\bookishcoverseriffont\bfseries #1}%
}

\newcommand{\bookish@coverSubtitleText}[1]{%
  {\bookishsansfont\itshape #1}%
}

\newcommand{\bookish@coverAuthorText}[1]{%
  {\bookishcoverseriffont\bfseries #1}%
}

\newcommand{\bookish@coverAddressText}[1]{%
  {\bookishsansfont\itshape #1}%
}

\newcommand{\bookish@coverMetaText}[1]{%
  {\bookishsansfont\addfontfeatures{LetterSpace=24}\MakeUppercase{#1}}%
}

\newcommand{\bookish@drawpublisherlogo}[2]{%
  \ifstrempty{\bookish@publisherlogo}{}{%
    \node[#1] {\includegraphics[width=#2]{\bookish@publisherlogo}};%
  }%
}

% Image-backed covers need footer blocks that stay together instead of floating pieces.
\newcommand{\bookish@imagebgparalign}[1]{%
  \ifdefstring{#1}{left}{\raggedright}{%
    \ifdefstring{#1}{right}{\raggedleft}{\centering}%
  }%
}

% Subtitle placement is configurable: above or below the title.
\newcommand{\bookish@ifsubtitleabove}[2]{%
  \ifdefstring{\bookish@subtitleposition}{above}{#1}{#2}%
}

\newcommand{\bookish@drawstatustag}{%
  \ifstrempty{\bookish@publishstatuslabel}{}{%
    \node[
      anchor=north west,
      fill=bookishaccent,
      text=bookishcoverbg,
      rounded corners=2pt,
      inner xsep=10pt,
      inner ysep=5pt,
      font=\bookishsansfont\bfseries\fontsize{10}{10}\selectfont
    ] at ([xshift=16pt,yshift=-16pt] current page.north west) {%
      \bookish@coverMetaText{\bookish@publishstatuslabel}%
    };
  }%
}

