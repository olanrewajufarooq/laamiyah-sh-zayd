  \bookish@applyfrontpageoverride{\bookish@frontpage@translatorfontsize}{\bookish@imagebgtranslatorfontsize}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@publisherblockfrombottom}{\bookish@imagebgpublisherfrombottom}%
