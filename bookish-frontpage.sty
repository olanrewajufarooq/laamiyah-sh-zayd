\newcommand{\bookish@setupimagebgstyle}{%
  \edef\bookish@imagebgfilepath{assets/frontimages/\bookishfrontpage@style.jpg}%
  \renewcommand{\bookish@imagebgtitlexoffset}{0pt}%
  \renewcommand{\bookish@imagebgtitlefromtop}{0.16\paperheight}%
