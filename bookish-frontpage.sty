  \renewcommand{\bookish@imagebgauthorxoffset}{0pt}%
  \renewcommand{\bookish@imagebgauthorfromtop}{0.82\paperheight}%
  \renewcommand{\bookish@imagebgauthoranchor}{south}%
  \renewcommand{\bookish@imagebgauthoralign}{center}%
  \renewcommand{\bookish@imagebgauthorwidth}{0.58\paperwidth}%
  \renewcommand{\bookish@imagebgauthorpanelopacity}{0.22}%
  \renewcommand{\bookish@imagebgauthorfontsize}{19}%
  \renewcommand{\bookish@imagebgaddressfontsize}{11}%
