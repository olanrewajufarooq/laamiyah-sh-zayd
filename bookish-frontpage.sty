  \edef\bookish@imagebgfilepath{assets/frontimages/\bookishfrontpage@style.jpg}%
  \renewcommand{\bookish@imagebgtitlepos}{([yshift=-0.16\paperheight]current page.north)}%
  \renewcommand{\bookish@imagebgtitleanchor}{north}%
  \renewcommand{\bookish@imagebgtitlealign}{center}%
  \renewcommand{\bookish@imagebgtitlewidth}{0.72\paperwidth}%
  \renewcommand{\bookish@imagebgtitlepanelopacity}{0.30}%
  \renewcommand{\bookish@imagebgtitlefontsize}{34}%
  \renewcommand{\bookish@imagebgsubtitlefontsize}{15}%
  \renewcommand{\bookish@imagebgauthorpos}{([yshift=0.18\paperheight]current page.south)}%
  \renewcommand{\bookish@imagebgauthoranchor}{south}%
  \renewcommand{\bookish@imagebgauthoralign}{center}%
  \renewcommand{\bookish@imagebgauthorwidth}{0.58\paperwidth}%
  \renewcommand{\bookish@imagebgauthorpanelopacity}{0.22}%
  \renewcommand{\bookish@imagebgauthorfontsize}{19}%
  \renewcommand{\bookish@imagebgaddressfontsize}{11}%
  \renewcommand{\bookish@imagebgpublisherpos}{([yshift=1.0cm]current page.south)}%
  \renewcommand{\bookish@imagebgpublisheranchor}{south}%
  \renewcommand{\bookish@imagebgpublisheralign}{center}%
  \renewcommand{\bookish@imagebgpublisherwidth}{0.20\paperwidth}%
  \renewcommand{\bookish@imagebgtranslatorpos}{([yshift=1.95cm]current page.south)}%
  \renewcommand{\bookish@imagebgtranslatoranchor}{south}%
  \renewcommand{\bookish@imagebgtranslatoralign}{center}%
  \renewcommand{\bookish@imagebgtranslatorwidth}{0.40\paperwidth}%
  \renewcommand{\bookish@imagebgmetapanelopacity}{0.00}%
  \renewcommand{\bookish@imagebglogowidth}{0.055\textwidth}%
  \ifcsdef{bookish@imagebgsetup@\bookishfrontpage@style}{%
    \csname bookish@imagebgsetup@\bookishfrontpage@style\endcsname
  }{}%
}

% Full-bleed image cover derived from the local imagebg template and tuned per source image.
\newcommand{\bookishfrontpageimagebg}{%
  \bookish@setupimagebgstyle
  \node[anchor=south west, inner sep=0pt] at (current page.south west) {%
    \includegraphics[width=\paperwidth,height=\paperheight]{\bookish@imagebgfilepath}%
  };
  \bookish@drawstatustag
  \node[
    text=bookishcoverfg,
    fill=bookishcoverbg,
    fill opacity=\bookish@imagebgtitlepanelopacity,
    text opacity=1,
    rounded corners=16pt,
    inner xsep=16pt,
    inner ysep=15pt,
    text width=\bookish@imagebgtitlewidth,
    align=\bookish@imagebgtitlealign,
    anchor=\bookish@imagebgtitleanchor
  ] at \bookish@imagebgtitlepos {%
    \bookish@ifsubtitleabove{%
      \ifstrempty{\bookish@subtitle}{}{{\color{bookishcovermuted}\fontsize{\bookish@imagebgsubtitlefontsize}{\numexpr\bookish@imagebgsubtitlefontsize+2\relax}\selectfont\bookish@coverSubtitleText{\bookish@subtitle}\par\vspace{4pt}}%
      }%
      {\fontsize{\bookish@imagebgtitlefontsize}{\numexpr\bookish@imagebgtitlefontsize+2\relax}\selectfont\bookish@coverTitleText{\bookish@title}}%
    }{%
      {\fontsize{\bookish@imagebgtitlefontsize}{\numexpr\bookish@imagebgtitlefontsize+2\relax}\selectfont\bookish@coverTitleText{\bookish@title}}%
      \ifstrempty{\bookish@subtitle}{}{\par\vspace{4pt}{\color{bookishcovermuted}\fontsize{\bookish@imagebgsubtitlefontsize}{\numexpr\bookish@imagebgsubtitlefontsize+2\relax}\selectfont\bookish@coverSubtitleText{\bookish@subtitle}}}%
    }%
  };
  \node[
    text=bookishcoverfg,
    fill=bookishcoverbg,
    fill opacity=\bookish@imagebgauthorpanelopacity,
    text opacity=1,
    rounded corners=14pt,
    inner xsep=14pt,
    inner ysep=11pt,
    text width=\bookish@imagebgauthorwidth,
    align=\bookish@imagebgauthoralign,
    anchor=\bookish@imagebgauthoranchor
  ] at \bookish@imagebgauthorpos {%
    \ifstrempty{\bookish@authoraddress}{}{{\color{bookishcovermuted}\fontsize{\bookish@imagebgaddressfontsize}{\numexpr\bookish@imagebgaddressfontsize+2\relax}\selectfont\bookish@coverAddressText{\bookish@authoraddress}}\par\vspace{2pt}}%
    {\fontsize{\bookish@imagebgauthorfontsize}{\numexpr\bookish@imagebgauthorfontsize+2\relax}\selectfont\bookish@coverAuthorText{\bookish@author}}%
  };
  \node[
    text=bookishcoverfg,
    fill=bookishcoverbg,
    fill opacity=\bookish@imagebgmetapanelopacity,
    text opacity=1,
    rounded corners=10pt,
    inner xsep=10pt,
    inner ysep=8pt,
    anchor=\bookish@imagebgpublisheranchor,
    text width=\bookish@imagebgpublisherwidth,
    align=\bookish@imagebgpublisheralign,
    font=\fontsize{11}{11}\bookishsansfont
  ] (publisher) at \bookish@imagebgpublisherpos {%
    \textcolor{bookishcovermuted}{\bookish@coverMetaText{\bookish@publishername}}%
  };
  \bookish@drawpublisherlogo{anchor=north, above=4pt of publisher.north}{\bookish@imagebglogowidth}
  \ifstrempty{\bookish@translator}{}{%
    \node[
      text=bookishcoverfg,
      fill=bookishcoverbg,
      fill opacity=\bookish@imagebgmetapanelopacity,
      text opacity=1,
