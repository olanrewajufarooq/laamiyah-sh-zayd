\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bookish-frontpage}[2026/04/17 Frontpage styles for bookish]
% Usage:
% Loaded by bookish.sty. Select with \usepackage[frontpage=star]{bookish}
