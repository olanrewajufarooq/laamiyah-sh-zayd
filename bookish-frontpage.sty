% Resolve the public style name to the matching frontpage renderer.
\newcommand{\bookishprintfontpage}{%
  \bookish@ifimagebgstyle{\bookishfrontpage@style}{%
    \bookishfrontpageimagebg
  }{%
    \ifdefstring{\bookishfrontpage@style}{star}{%
        \bookishfrontpageelegant
    }{%
      \ifdefstring{\bookishfrontpage@style}{flower}{%
        \bookishfrontpageflowercenter
      }{%
        \ifdefstring{\bookishfrontpage@style}{circle}{%
          \bookishfrontpagespiralcirclemid
        }{%
          \bookishfrontpageelegant
        }%
      }%
    }%
  }%
}

% Resolve the public style name to the matching backmatter renderer.
\newcommand{\bookishprintbackmatter}{%
  \bookish@ifimagebgstyle{\bookishfrontpage@style}{%
    \bookishbackmatterimagebg
  }{%
    \ifdefstring{\bookishfrontpage@style}{star}{%
        \bookishbackmatterelegant
    }{%
      \ifdefstring{\bookishfrontpage@style}{flower}{%
        \bookishbackmatterflowercenter
      }{%
        \ifdefstring{\bookishfrontpage@style}{circle}{%
          \bookishbackmatterspiralcirclemid
        }{%
          \bookishbackmatterelegant
        }%
      }%
    }%
  }%
}
