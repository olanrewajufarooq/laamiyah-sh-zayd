  \renewcommand{\bookish@imagebgtranslatorxoffset}{0pt}%
  \renewcommand{\bookish@imagebgtranslatorfrombottom}{0.093\paperheight}%
  \renewcommand{\bookish@imagebgtranslatoranchor}{south}%
  \renewcommand{\bookish@imagebgtranslatoralign}{center}%
  \renewcommand{\bookish@imagebgtranslatorwidth}{0.40\paperwidth}%
  \renewcommand{\bookish@imagebgtranslatorfontsize}{12}%
  \renewcommand{\bookish@imagebgmetapanelopacity}{0.00}%
  \renewcommand{\bookish@imagebglogowidth}{0.055\textwidth}%
  \ifcsdef{bookish@imagebgsetup@\bookishfrontpage@style}{%
    \csname bookish@imagebgsetup@\bookishfrontpage@style\endcsname
  }{}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@titleblockfromtop}{\bookish@imagebgtitlefromtop}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@titleblockwidth}{\bookish@imagebgtitlewidth}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@titlefontsize}{\bookish@imagebgtitlefontsize}%
  \bookish@applyfrontpageoverride{\bookish@frontpage@subtitlefontsize}{\bookish@imagebgsubtitlefontsize}%
