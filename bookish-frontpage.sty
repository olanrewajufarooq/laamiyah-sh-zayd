\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bookish-frontpage}[2026/04/17 Frontpage styles for bookish]
% Usage:
% Loaded by bookish.sty. Select with \usepackage[frontpage=star]{bookish}
% Available styles: star, flower, circle.
% Matching backmatter pages are rendered through \bookmakebackmatter.

% Frontpage rendering relies on TikZ composition and a few helper comparisons.
\RequirePackage{etoolbox}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{calc,math,positioning,shapes.geometric}

\newcommand{\bookishfrontpage@style}{star}

% Marker commands let the package detect image-background frontmatter styles.
\expandafter\def\csname bookish@imagebgstyle@bluelight\endcsname{}
