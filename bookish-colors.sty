% Swap the shared named colors to the palette associated with the active theme.
\newcommand{\bookishapplytheme}[1]{%
  \ifcsdef{bookish@theme@#1}{%
    \csname bookish@theme@#1\endcsname
  }{%
    \bookish@theme@purple
  }%
}
